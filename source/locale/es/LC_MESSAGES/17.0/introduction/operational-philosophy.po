#: ../../source/17.0/introduction/operational-philosophy.rst:2
msgid "1.5 Operational Philosophy"
msgstr ""

#: ../../source/17.0/introduction/operational-philosophy.rst:5
msgid "Core Idea"
msgstr ""

#: ../../source/17.0/introduction/operational-philosophy.rst:7
msgid ""
"The TMS is designed to eliminate operational uncertainty by making "
"execution state explicit, traceable, and consistent across planning, "
"mobile execution, and administrative workflows."
msgstr ""

#: ../../source/17.0/introduction/operational-philosophy.rst:11
msgid "Principles"
msgstr ""

#: ../../source/17.0/introduction/operational-philosophy.rst:13
msgid ""
"Model-first: orders are transformed into execution units "
"(legs/stops/trips)."
msgstr ""

#: ../../source/17.0/introduction/operational-philosophy.rst:14
msgid "Controlled state transitions across operational entities."
msgstr ""

#: ../../source/17.0/introduction/operational-philosophy.rst:15
msgid ""
"Traceability is first-class: every relevant event is recorded with "
"timestamp and context."
msgstr ""

#: ../../source/17.0/introduction/operational-philosophy.rst:16
msgid "Separation of concerns: planning vs execution vs administration."
msgstr ""

#: ../../source/17.0/introduction/operational-philosophy.rst:17
msgid "Configuration over code where possible."
msgstr ""

