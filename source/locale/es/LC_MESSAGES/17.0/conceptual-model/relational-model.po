#: ../../source/17.0/conceptual-model/relational-model.rst:4
msgid ""
"The Conceptual Relational Model defines how the core entities of Guraify "
"TMS are structurally linked."
msgstr ""

#: ../../source/17.0/conceptual-model/relational-model.rst:7
msgid "Its objective is to formalize cardinalities and dependencies between:"
msgstr ""

#: ../../source/17.0/conceptual-model/relational-model.rst:9
msgid "Order"
msgstr ""

#: ../../source/17.0/conceptual-model/relational-model.rst:10
msgid "Leg"
msgstr ""

#: ../../source/17.0/conceptual-model/relational-model.rst:11
msgid "Stop"
msgstr ""

#: ../../source/17.0/conceptual-model/relational-model.rst:12
msgid "Trip"
msgstr ""

#: ../../source/17.0/conceptual-model/relational-model.rst:14
msgid ""
"This model represents the logical foundation upon which the technical "
"architecture of the system is built."
msgstr ""

#: ../../source/17.0/conceptual-model/relational-model.rst:18
msgid "2.6.1 Core Entities"
msgstr ""

#: ../../source/17.0/conceptual-model/relational-model.rst:21
msgid "ORDER"
msgstr ""

#: ../../source/17.0/conceptual-model/relational-model.rst:23
msgid "Represents the commercial service commitment."
msgstr ""

#: ../../source/17.0/conceptual-model/relational-model.rst:25
msgid "Generates revenue"
msgstr ""

#: ../../source/17.0/conceptual-model/relational-model.rst:26
msgid "May contain multiple Legs"
msgstr ""

#: ../../source/17.0/conceptual-model/relational-model.rst:27
msgid "Linked to Customer and Project"
msgstr ""

#: ../../source/17.0/conceptual-model/relational-model.rst:28
msgid "Defines pricing logic"
msgstr ""

#: ../../source/17.0/conceptual-model/relational-model.rst:31
msgid "LEG"
msgstr ""

#: ../../source/17.0/conceptual-model/relational-model.rst:33
msgid "Operational unit belonging to an Order."
msgstr ""

#: ../../source/17.0/conceptual-model/relational-model.rst:35
msgid "Defines origin and destination"
msgstr ""

#: ../../source/17.0/conceptual-model/relational-model.rst:36
msgid "Generates Stops"
msgstr ""

#: ../../source/17.0/conceptual-model/relational-model.rst:37
msgid "Carries goods and time constraints"
msgstr ""

#: ../../source/17.0/conceptual-model/relational-model.rst:40
msgid "STOP"
msgstr ""

#: ../../source/17.0/conceptual-model/relational-model.rst:42
msgid "Physical operational event derived from a Leg."
msgstr ""

#: ../../source/17.0/conceptual-model/relational-model.rst:44
msgid "Pickup / Delivery / Hub / Technical event"
msgstr ""

#: ../../source/17.0/conceptual-model/relational-model.rst:45
msgid "Minimum planning unit"
msgstr ""

#: ../../source/17.0/conceptual-model/relational-model.rst:46
msgid "Assigned to a Trip"
msgstr ""

#: ../../source/17.0/conceptual-model/relational-model.rst:49
msgid "TRIP"
msgstr ""

#: ../../source/17.0/conceptual-model/relational-model.rst:51
msgid "Operational execution unit."
msgstr ""

#: ../../source/17.0/conceptual-model/relational-model.rst:53
msgid "Groups multiple Stops"
msgstr ""

#: ../../source/17.0/conceptual-model/relational-model.rst:54
msgid "Assigned to carrier/resource"
msgstr ""

#: ../../source/17.0/conceptual-model/relational-model.rst:55
msgid "Generates cost"
msgstr ""

#: ../../source/17.0/conceptual-model/relational-model.rst:58
msgid "2.6.2 Structural Cardinalities"
msgstr ""

#: ../../source/17.0/conceptual-model/relational-model.rst:60
msgid "The conceptual relational structure can be represented as:"
msgstr ""

#: ../../source/17.0/conceptual-model/relational-model.rst:62
msgid ""
"ORDER (1) ──────── (N) LEG LEG (1) ──────── (N) STOP STOP (N) ──────── "
"(1) TRIP"
msgstr ""

#: ../../source/17.0/conceptual-model/relational-model.rst:68
msgid "ORDER → LEG (1:N)"
msgstr ""

#: ../../source/17.0/conceptual-model/relational-model.rst:70
msgid "One Order may contain multiple Legs."
msgstr ""

#: ../../source/17.0/conceptual-model/relational-model.rst:71
msgid "Each Leg belongs exclusively to one Order."
msgstr ""

#: ../../source/17.0/conceptual-model/relational-model.rst:73
msgid ""
"This is a strong structural dependency. If the Order is removed, its Legs"
" lose logical meaning."
msgstr ""

#: ../../source/17.0/conceptual-model/relational-model.rst:77
msgid "LEG → STOP (1:N)"
msgstr ""

#: ../../source/17.0/conceptual-model/relational-model.rst:79
msgid "A Leg generates at least two Stops (load and unload)."
msgstr ""

#: ../../source/17.0/conceptual-model/relational-model.rst:80
msgid "Additional Stops may exist in complex logistics scenarios."
msgstr ""

#: ../../source/17.0/conceptual-model/relational-model.rst:82
msgid ""
"This is a strong structural dependency. Stops cannot exist without their "
"parent Leg."
msgstr ""

#: ../../source/17.0/conceptual-model/relational-model.rst:86
msgid "STOP → TRIP (N:1)"
msgstr ""

#: ../../source/17.0/conceptual-model/relational-model.rst:88
msgid "A Stop belongs to exactly one Trip during operational execution."
msgstr ""

#: ../../source/17.0/conceptual-model/relational-model.rst:89
msgid "A Trip groups multiple Stops."
msgstr ""

#: ../../source/17.0/conceptual-model/relational-model.rst:91
msgid ""
"This represents an operational assignment dependency, not a hierarchical "
"construction dependency."
msgstr ""

#: ../../source/17.0/conceptual-model/relational-model.rst:96
msgid "2.6.3 Indirect ORDER ↔ TRIP Relationship"
msgstr ""

#: ../../source/17.0/conceptual-model/relational-model.rst:98
msgid "There is no direct structural relation between Order and Trip."
msgstr ""

#: ../../source/17.0/conceptual-model/relational-model.rst:100
msgid "However, an indirect relationship exists through Stops:"
msgstr ""

#: ../../source/17.0/conceptual-model/relational-model.rst:102
msgid "A Trip may contain Stops originating from multiple Orders."
msgstr ""

#: ../../source/17.0/conceptual-model/relational-model.rst:103
msgid "An Order may be distributed across multiple Trips."
msgstr ""

#: ../../source/17.0/conceptual-model/relational-model.rst:105
msgid ""
"Conceptually, this results in an indirect N:M relationship between Order "
"and Trip."
msgstr ""

#: ../../source/17.0/conceptual-model/relational-model.rst:108
msgid "This behavior is especially relevant in:"
msgstr ""

#: ../../source/17.0/conceptual-model/relational-model.rst:110
msgid "Groupage operations"
msgstr ""

#: ../../source/17.0/conceptual-model/relational-model.rst:111
msgid "Last-mile scenarios"
msgstr ""

#: ../../source/17.0/conceptual-model/relational-model.rst:112
msgid "Multi-client planning"
msgstr ""

#: ../../source/17.0/conceptual-model/relational-model.rst:113
msgid "Multi-hub operations"
msgstr ""

#: ../../source/17.0/conceptual-model/relational-model.rst:115
msgid ""
"This structural decoupling is intentional and enables operational "
"flexibility and economic independence."
msgstr ""

#: ../../source/17.0/conceptual-model/relational-model.rst:120
msgid "2.6.4 Structural vs Operational Dependencies"
msgstr ""

#: ../../source/17.0/conceptual-model/relational-model.rst:122
msgid "The model defines two types of dependencies:"
msgstr ""

#: ../../source/17.0/conceptual-model/relational-model.rst:125
msgid "Strong Structural Dependencies"
msgstr ""

#: ../../source/17.0/conceptual-model/relational-model.rst:127
msgid "Leg depends on Order."
msgstr ""

#: ../../source/17.0/conceptual-model/relational-model.rst:128
msgid "Stop depends on Leg."
msgstr ""

#: ../../source/17.0/conceptual-model/relational-model.rst:130
msgid "If the parent entity is deleted, child entities lose logical validity."
msgstr ""

#: ../../source/17.0/conceptual-model/relational-model.rst:132
msgid ""
"These relationships represent hierarchical construction of the logistics "
"structure."
msgstr ""

#: ../../source/17.0/conceptual-model/relational-model.rst:136
msgid "Weak Operational Dependencies"
msgstr ""

#: ../../source/17.0/conceptual-model/relational-model.rst:138
msgid "Stop is assigned to Trip."
msgstr ""

#: ../../source/17.0/conceptual-model/relational-model.rst:139
msgid "Trip does not structurally depend on a specific Order."
msgstr ""

#: ../../source/17.0/conceptual-model/relational-model.rst:141
msgid "This allows:"
msgstr ""

#: ../../source/17.0/conceptual-model/relational-model.rst:143
msgid "Replanning"
msgstr ""

#: ../../source/17.0/conceptual-model/relational-model.rst:144
msgid "Trip reassignment"
msgstr ""

#: ../../source/17.0/conceptual-model/relational-model.rst:145
msgid "Dynamic optimization"
msgstr ""

#: ../../source/17.0/conceptual-model/relational-model.rst:146
msgid "Separation between revenue and cost"
msgstr ""

#: ../../source/17.0/conceptual-model/relational-model.rst:150
msgid "2.6.5 Architectural Impact"
msgstr ""

#: ../../source/17.0/conceptual-model/relational-model.rst:152
msgid "This relational architecture enables:"
msgstr ""

#: ../../source/17.0/conceptual-model/relational-model.rst:154
msgid "Operational scalability"
msgstr ""

#: ../../source/17.0/conceptual-model/relational-model.rst:155
msgid "Event-based advanced planning"
msgstr ""

#: ../../source/17.0/conceptual-model/relational-model.rst:156
msgid "Grouping of multiple Orders into a single Trip"
msgstr ""

#: ../../source/17.0/conceptual-model/relational-model.rst:157
msgid "Multidimensional economic allocation"
msgstr ""

#: ../../source/17.0/conceptual-model/relational-model.rst:158
msgid "Independence between invoicing and execution"
msgstr ""

#: ../../source/17.0/conceptual-model/relational-model.rst:160
msgid "The structural separation between:"
msgstr ""

#: ../../source/17.0/conceptual-model/relational-model.rst:162
msgid "Commercial Commitment (Order)"
msgstr ""

#: ../../source/17.0/conceptual-model/relational-model.rst:164
msgid "and"
msgstr ""

#: ../../source/17.0/conceptual-model/relational-model.rst:166
msgid "Operational Execution (Trip)"
msgstr ""

#: ../../source/17.0/conceptual-model/relational-model.rst:168
msgid "is only possible due to this relational architecture."
msgstr ""

#: ../../source/17.0/conceptual-model/relational-model.rst:170
msgid ""
"This decoupled model allows Guraify TMS to scale from simple direct-load "
"operations to complex multi-hub and large-scale last-mile scenarios."
msgstr ""

